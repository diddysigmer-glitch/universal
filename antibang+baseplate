-- --- 4. BASE PLATFORM LOGIC (CONTROLLED BY TOGGLE) ---
local PLATFORM_SIZE = 2000
local spawn_Y = -1 
local extendedFloor = nil
local beams = {}
local mainLoop = nil

local function createPlatform()
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if hrp then
        spawn_Y = hrp.Position.Y - 3.45
    end

    extendedFloor = Instance.new("Part", workspace)
    extendedFloor.Name = "FollowingBaseplate_Managed"
    extendedFloor.Size = Vector3.new(PLATFORM_SIZE, 1, PLATFORM_SIZE)
    extendedFloor.Anchored = true
    extendedFloor.CanCollide = true
    extendedFloor.Transparency = 1 

    beams = {}
    local function createEdgeLine(pos1, pos2)
        local att1 = Instance.new("Attachment", extendedFloor)
        att1.Position = pos1
        local att2 = Instance.new("Attachment", extendedFloor)
        att2.Position = pos2
        local beam = Instance.new("Beam", extendedFloor)
        beam.Attachment0, beam.Attachment1 = att1, att2
        beam.Width0, beam.Width1, beam.LightEmission, beam.FaceCamera = 1, 1, 1, true
        table.insert(beams, beam)
    end

    local offset = PLATFORM_SIZE / 2
    createEdgeLine(Vector3.new(-offset, 0.5, -offset), Vector3.new(offset, 0.5, -offset))
    createEdgeLine(Vector3.new(offset, 0.5, -offset), Vector3.new(offset, 0.5, offset))
    createEdgeLine(Vector3.new(offset, 0.5, offset), Vector3.new(-offset, 0.5, offset))
    createEdgeLine(Vector3.new(-offset, 0.5, offset), Vector3.new(-offset, 0.5, -offset))

    mainLoop = RunService.RenderStepped:Connect(function()
        local currentHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if currentHrp and extendedFloor then 
            extendedFloor.Position = Vector3.new(currentHrp.Position.X, spawn_Y, currentHrp.Position.Z) 
        end
        local color = Color3.fromHSV((tick() * 0.05) % 1, 0.8, 1)
        for _, beam in pairs(beams) do beam.Color = ColorSequence.new(color) end
    end)
end

local function destroyPlatform()
    if mainLoop then mainLoop:Disconnect() end
    if extendedFloor then extendedFloor:Destroy() end
    beams = {}
end

-- --- 5. ANTI-BANG INTEGRATION ---
local boundKey = nil
local isBinding = false
local isRunning = false
local inputConnection = nil
local healthGuard = nil
local deathConnection = nil
local voidLoop = nil

local function executeAntiBang()
    if isRunning or isBinding then return end
    isRunning = true

    local character = player.Character
    if not character then isRunning = false return end

    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    if not rootPart or not humanoid then isRunning = false return end

    local startCF = rootPart.CFrame
    local startPos = startCF.Position

    local guard
    guard = RunService.PreRender:Connect(function()
        if humanoid and humanoid.Parent then
            humanoid.Health = humanoid.MaxHealth
        else
            guard:Disconnect()
        end
    end)
    healthGuard = guard

    deathConnection = humanoid.Died:Connect(function()
        humanoid.Health = humanoid.MaxHealth
        humanoid:LoadCharacter()
    end)

    rootPart.AssemblyLinearVelocity = Vector3.zero
    rootPart.AssemblyAngularVelocity = Vector3.zero

    local nullZonePos = Vector3.new(startPos.X, -300000, startPos.Z)

    local duration = 1
    local startTime = os.clock()
    local running = true
    local angleCounter = 0

    voidLoop = task.spawn(function()
        while running do
            if os.clock() - startTime >= duration then
                running = false
                break
            end
            angleCounter = angleCounter + 180
            local rot = CFrame.Angles(0, math.rad(angleCounter), 0)
            rootPart.CFrame = CFrame.new(nullZonePos) * rot
            rootPart.AssemblyLinearVelocity = Vector3.zero
            rootPart.AssemblyAngularVelocity = Vector3.zero
            task.wait()
        end
    end)

    task.wait(duration)

    running = false
    if voidLoop then
        task.cancel(voidLoop)
        voidLoop = nil
    end

    rootPart.CFrame = startCF
    rootPart.AssemblyLinearVelocity = Vector3.zero
    rootPart.AssemblyAngularVelocity = Vector3.zero

    if guard then
        guard:Disconnect()
        healthGuard = nil
    end
    if deathConnection then
        deathConnection:Disconnect()
        deathConnection = nil
    end
    humanoid.Health = humanoid.MaxHealth

    isRunning = false
end

