-- Destroy Script (Smart Countdown)
destroyBtn.MouseButton1Click:Connect(function()
    if not confirmMode then
        confirmMode = true
        local countdown = 5
        destroyBtn.Text = "Are you sure? (" .. countdown .. ")"
        destroyBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)

        if countdownTask then
            task.cancel(countdownTask)
            countdownTask = nil
        end

        countdownTask = task.spawn(function()
            while countdown > 0 do
                task.wait(1)
                countdown = countdown - 1
                if not confirmMode then break end
                destroyBtn.Text = "Are you sure? (" .. countdown .. ")"
            end
            if confirmMode then
                confirmMode = false
                destroyBtn.Text = "Destroy Script"
                destroyBtn.BackgroundColor3 = Color3.fromRGB(160, 30, 30)
            end
            countdownTask = nil
        end)

    else
        -- SECOND CLICK → DESTROY EVERYTHING
        if countdownTask then
            task.cancel(countdownTask)
            countdownTask = nil
        end
        if inputConnection then inputConnection:Disconnect() end
        if healthGuard then healthGuard:Disconnect() end
        if deathConnection then deathConnection:Disconnect() end
        if voidLoop then task.cancel(voidLoop) end
        destroyPlatform()
        sg:Destroy()
        _G.KurtLoaded = false
        StarterGui:SetCore("SendNotification", {Title = "KURT.WTF", Text = "Script Terminated.", Duration = 3})
    end
end)

