--[[
  UI + Antibang Keybind (NULL ZONE: Y = -300,000 – MINIMAL LOADING PAUSE)
  - Teleports straight down to Y = -300,000 (same X and Z) – no horizontal movement.
  - Spins 180° per frame for 1 second.
  - Health locked, visible to other players.
  - No terrain streaming = almost zero "Gameplay Paused".
]]

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- ==============================
-- UI BUILD (same as before)
-- ==============================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AntibangGUI"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 240, 0, 115)
frame.Position = UDim2.new(0.5, -120, 0.5, -57)
frame.BackgroundColor3 = Color3.fromRGB(28, 28, 33)
frame.BorderSizePixel = 0
frame.Draggable = true
frame.Active = true
frame.Parent = screenGui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 28)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundTransparency = 1
title.Text = "Anti-Bang Hub"
title.TextColor3 = Color3.fromRGB(220, 220, 220)
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.Parent = frame

local bindButton = Instance.new("TextButton")
bindButton.Size = UDim2.new(0.9, 0, 0, 34)
bindButton.Position = UDim2.new(0.05, 0, 0.35, 0)
bindButton.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
bindButton.TextColor3 = Color3.fromRGB(255, 255, 255)
bindButton.Text = "Antibang Keybind [None]"
bindButton.Font = Enum.Font.Gotham
bindButton.Parent = frame

local destroyButton = Instance.new("TextButton")
destroyButton.Size = UDim2.new(0.9, 0, 0, 28)
destroyButton.Position = UDim2.new(0.05, 0, 0.72, 0)
destroyButton.BackgroundColor3 = Color3.fromRGB(160, 30, 30)
destroyButton.TextColor3 = Color3.fromRGB(255, 255, 255)
destroyButton.Text = "Destroy Script"
destroyButton.Font = Enum.Font.Gotham
destroyButton.Parent = frame

-- ==============================
-- STATE
-- ==============================
local boundKey = nil
local isBinding = false
local isRunning = false
local inputConnection = nil
local healthGuard = nil
local deathConnection = nil
local voidLoop = nil

-- ==============================
-- ANTIBANG SEQUENCE (Y = -300,000)
-- ==============================
local function executeAntiBang()
    if isRunning or isBinding then return end
    isRunning = true

    local character = player.Character
    if not character then isRunning = false return end

    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    if not rootPart or not humanoid then isRunning = false return end

    local startCF = rootPart.CFrame
    local startPos = startCF.Position

    -- Health lock
    local guard
    guard = RunService.PreRender:Connect(function()
        if humanoid and humanoid.Parent then
            humanoid.Health = humanoid.MaxHealth
        else
            guard:Disconnect()
        end
    end)
    healthGuard = guard

    -- Died fallback
    deathConnection = humanoid.Died:Connect(function()
        humanoid.Health = humanoid.MaxHealth
        humanoid:LoadCharacter()
    end)

    -- Reset physics
    rootPart.AssemblyLinearVelocity = Vector3.zero
    rootPart.AssemblyAngularVelocity = Vector3.zero

    -- NULL ZONE: straight down to Y = -300,000 (same X and Z)
    local nullZonePos = Vector3.new(startPos.X, -300000, startPos.Z)

    -- Spin + hold loop (1 second)
    local duration = 1
    local startTime = os.clock()
    local running = true
    local angleCounter = 0

    voidLoop = task.spawn(function()
        while running do
            if os.clock() - startTime >= duration then
                running = false
                break
            end

            angleCounter = angleCounter + 180
            local rot = CFrame.Angles(0, math.rad(angleCounter), 0)
            rootPart.CFrame = CFrame.new(nullZonePos) * rot

            rootPart.AssemblyLinearVelocity = Vector3.zero
            rootPart.AssemblyAngularVelocity = Vector3.zero

            task.wait()
        end
    end)

    task.wait(duration)

    running = false
    if voidLoop then
        task.cancel(voidLoop)
        voidLoop = nil
    end

    -- Return to start, stop spinning
    rootPart.CFrame = startCF
    rootPart.AssemblyLinearVelocity = Vector3.zero
    rootPart.AssemblyAngularVelocity = Vector3.zero

    -- Clean up
    if guard then
        guard:Disconnect()
        healthGuard = nil
    end
    if deathConnection then
        deathConnection:Disconnect()
        deathConnection = nil
    end
    humanoid.Health = humanoid.MaxHealth

    isRunning = false
    print("✓ Anti-bang complete – Y=-300k null zone (minimal pause).")
end

-- ==============================
-- KEYBOARD & UI EVENTS
-- ==============================
inputConnection = UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if isBinding then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            boundKey = input.KeyCode
            bindButton.Text = "Antibang Keybind [" .. boundKey.Name .. "]"
            isBinding = false
            print("✓ Key bound to:", boundKey.Name)
        end
        return
    end

    if boundKey and input.KeyCode == boundKey then
        task.spawn(executeAntiBang)
    end
end)

bindButton.MouseButton1Click:Connect(function()
    if isBinding then
        isBinding = false
        bindButton.Text = "Antibang Keybind [" .. (boundKey and boundKey.Name or "None") .. "]"
        return
    end
    isBinding = true
    bindButton.Text = "Press any key..."
end)

destroyButton.MouseButton1Click:Connect(function()
    if voidLoop then
        task.cancel(voidLoop)
        voidLoop = nil
    end
    if inputConnection then inputConnection:Disconnect() end
    if healthGuard then healthGuard:Disconnect() end
    if deathConnection then deathConnection:Disconnect() end
    screenGui:Destroy()
    print("✓ Script and UI destroyed.")
end)
